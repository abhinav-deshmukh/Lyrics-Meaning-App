# Copy this file to .env and fill in your API keys
# OpenAI - for Whisper audio transcription
OPENAI_API_KEY=your_openai_key_here
# Anthropic - for Claude interpretation
ANTHROPIC_API_KEY=your_anthropic_key_here
# Optional: Cobalt API base URL for YouTube audio (avoids yt-dlp bot/JS issues on Railway).
# Only needed when deploying; use your own Cobalt instance (https://github.com/imputnet/cobalt).
# COBALT_API_URL=https://your-cobalt-instance.example.com
